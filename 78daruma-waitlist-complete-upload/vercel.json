{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/waitlist.html"
    },
    {
      "source": "/index.html",
      "destination": "/waitlist.html"
    },
    {
      "source": "/collection.html",
      "destination": "/waitlist.html"
    },
    {
      "source": "/product.html",
      "destination": "/waitlist.html"
    },
    {
      "source": "/philosophy.html",
      "destination": "/waitlist.html"
    },
    {
      "source": "/contact.html",
      "destination": "/waitlist.html"
    },
    {
      "source": "/checkout.html",
      "destination": "/waitlist.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/public/videos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
